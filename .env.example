# Dashboard - variables de entorno para desarrollo
#
# Copiar este archivo a .env y ajustar segun el entorno:
#   cp .env.example .env
#
# El backend debe estar corriendo con CORS_ORIGINS=* para que el browser
# acepte las llamadas cross-origin desde el dashboard.
#
#   CORS_ORIGINS=* pnpm dev   (en la terminal del backend)
#
# En produccion, Nginx sirve el dashboard y hace proxy_pass al backend,
# entonces apiBaseUrl queda en /api (mismo origen, no requiere CORS).

# URL del backend IoT. En dev: http://127.0.0.1:3000. En prod: /api.
NUXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3000
