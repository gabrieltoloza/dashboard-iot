# Dashboard - variables de entorno para desarrollo
#
# Copiar este archivo a .env y ajustar segun el entorno:
#   cp .env.example .env
#
# La app se sirve bajo app.baseURL (/dashboard-iot/). El cliente hace requests
# a <baseURL>/api/* y el proxy de Vite en dev las reenvia al backend,
# strippeando el prefijo /dashboard-iot.
#
# En produccion, Nginx sirve el dashboard y hace proxy_pass al backend,
# entonces apiBaseUrl queda en /api (mismo origen, no requiere CORS).

# Base usada por el cliente para construir URLs (debe coincidir con app.baseURL).
NUXT_PUBLIC_API_BASE_URL=/dashboard-iot/api

# Target del proxy de desarrollo (backend IoT).
NUXT_PUBLIC_API_PROXY_TARGET=http://127.0.0.1:3003
